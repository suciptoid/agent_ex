<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
>
  <div class="flex h-full min-h-0 flex-col">
    <%!-- Empty state / welcome --%>
    <div class="flex flex-1 items-center justify-center p-8">
      <%= if @available_agents == [] do %>
        <div class="text-center space-y-4">
          <div class="mx-auto flex size-16 items-center justify-center rounded-2xl bg-muted">
            <.icon name="hero-cpu-chip" class="size-8 text-muted-foreground" />
          </div>
          <div class="space-y-1">
            <p class="text-lg font-semibold text-foreground">No agents yet</p>
            <p class="text-sm text-muted-foreground">Create an agent first to start chatting.</p>
          </div>
          <.link id="setup-agent-button" navigate={~p"/agents"}>
            <.button>Create Agent</.button>
          </.link>
        </div>
      <% else %>
        <% unselected =
          Enum.reject(@available_agents, fn available_agent ->
            Enum.any?(@selected_agents, &(&1.id == available_agent.id))
          end) %>
        <div class="space-y-2 text-center">
          <p class="text-2xl font-semibold text-foreground/80">What can I help you with?</p>
          <p class="text-sm text-muted-foreground">Start typing to begin a new conversation.</p>
          <div class="pt-2">
            <AppWeb.ChatComponents.chat_agent_selector
              id="new-chat-agent-selector"
              class="justify-center"
              selected_agents={@selected_agents}
              unselected_agents={unselected}
              active_agent_id={@active_agent_id}
              set_active_event="set-active-agent"
              remove_event="remove-agent"
              add_event="add-agent"
              allow_remove_last={true}
              active_label="default"
            />
          </div>
        </div>
      <% end %>
    </div>

    <%!-- Message input --%>
    <%= if @available_agents != [] do %>
      <div class="mx-auto w-full max-w-3xl px-4 pb-4 sm:px-5 sm:pb-5 lg:px-6 lg:pb-6">
        <.form
          for={@message_form}
          id="chat-message-form"
          phx-change="validate"
          phx-submit="send"
          class="relative"
        >
          <.textarea
            field={@message_form[:content]}
            id="chat-message-input"
            rows="3"
            placeholder="Message… (Enter to send, Shift+Enter for new line)"
            phx-hook=".ChatInput"
            class="min-h-24 resize-none rounded-2xl px-4 py-4 pr-14"
          />
          <button
            id="chat-message-submit"
            type="submit"
            class="group absolute bottom-3 right-3 flex size-9 items-center justify-center rounded-xl bg-primary p-0 text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
            aria-label="Send message"
            title="Send message"
          >
            <.icon
              name="hero-paper-airplane"
              class="size-4 text-current transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
            />
          </button>
        </.form>
      </div>
    <% end %>
  </div>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatInput">
    export default {
      mounted() {
        this.el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            const form = this.el.closest("form");
            if (!form || form.dataset.streaming === "true") return;

            if (typeof form.requestSubmit === "function") {
              form.requestSubmit();
            } else {
              form.dispatchEvent(new Event("submit", { bubbles: true, cancelable: true }));
            }
          }
        });
      }
    }
  </script>
</Layouts.dashboard>
