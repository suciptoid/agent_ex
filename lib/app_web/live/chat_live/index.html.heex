<Layouts.dashboard flash={@flash} current_scope={@current_scope}>
  <div class="space-y-6">
    <div class="border-b border-border pb-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-2">
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Chat Rooms</h1>
          <p class="text-sm text-muted-foreground">
            Group your agents into persistent conversations and keep the context organized.
          </p>
        </div>

        <%= if @available_agents == [] do %>
          <.link id="setup-agent-button" navigate={~p"/agents"}>
            <.button>Create Agent First</.button>
          </.link>
        <% else %>
          <.link id="new-chat-button" patch={~p"/chat/new"}>
            <.button>New Chat</.button>
          </.link>
        <% end %>
      </div>
    </div>

    <%= if @available_agents == [] do %>
      <div class="rounded-2xl border border-dashed border-border bg-muted/30 p-6 text-sm text-muted-foreground">
        Chat rooms need at least one agent. Create an agent first, then return here to start a conversation.
      </div>
    <% end %>

    <%= if @live_action == :new and @form do %>
      <% selected_agent_ids =
        @form[:agent_ids].value |> List.wrap() |> Enum.reject(&(&1 in [nil, ""])) %>
      <% selected_commander_id = @form[:commander_agent_id].value %>

      <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
        <div class="w-full max-w-3xl rounded-2xl border border-border bg-background p-6 shadow-2xl">
          <div class="mb-6 space-y-2">
            <h2 class="text-2xl font-semibold text-foreground">{@page_title}</h2>
            <p class="text-sm text-muted-foreground">
              Give the room a title, choose the participating agents, and optionally mark a commander.
            </p>
          </div>

          <.form
            for={@form}
            id="chat-room-form"
            phx-change="validate"
            phx-submit="save"
            class="space-y-6"
          >
            <.input
              field={@form[:title]}
              type="text"
              label="Title"
              placeholder="Quarterly planning room"
            />

            <div class="space-y-3">
              <div class="space-y-1">
                <p class="text-sm font-medium text-foreground">Agents</p>
                <p class="text-xs text-muted-foreground">
                  Pick one or more agents. If you do not choose a commander, the first selected agent is used.
                </p>
              </div>

              <input type="hidden" name="chat_room[agent_ids][]" value="" />

              <div class="grid gap-3 md:grid-cols-2">
                <div
                  :for={agent <- @available_agents}
                  class={[
                    "rounded-2xl border p-4 transition",
                    if(agent.id in selected_agent_ids,
                      do: "border-primary bg-primary/5",
                      else: "border-border hover:border-primary/40"
                    )
                  ]}
                >
                  <div class="flex items-start gap-3">
                    <.checkbox
                      id={"chat-room-agent-#{agent.id}"}
                      name="chat_room[agent_ids][]"
                      value={agent.id}
                      checked={agent.id in selected_agent_ids}
                    />

                    <div class="min-w-0 flex-1 space-y-1">
                      <label for={"chat-room-agent-#{agent.id}"} class="block cursor-pointer">
                        <p class="text-sm font-medium text-foreground">{agent.name}</p>
                        <p class="text-xs text-muted-foreground">{agent.model}</p>
                      </label>
                    </div>

                    <label class="flex items-center gap-2 text-xs text-muted-foreground">
                      <.radio
                        id={"chat-room-commander-#{agent.id}"}
                        name="chat_room[commander_agent_id]"
                        value={agent.id}
                        checked={selected_commander_id == agent.id}
                      /> Commander
                    </label>
                  </div>
                </div>
              </div>

              <p
                :for={{message, _opts} <- @form[:agent_ids].errors}
                class="text-sm font-medium text-destructive"
              >
                {message}
              </p>
              <p
                :for={{message, _opts} <- @form[:commander_agent_id].errors}
                class="text-sm font-medium text-destructive"
              >
                {message}
              </p>
            </div>

            <div class="flex justify-end gap-3 pt-2">
              <.button type="button" variant="outline" phx-click={JS.patch(~p"/chat")}>
                Cancel
              </.button>
              <.button type="submit" phx-disable-with="Creating...">Create Chat</.button>
            </div>
          </.form>
        </div>
      </div>
    <% end %>

    <div id="chat-rooms" phx-update="stream" class="grid gap-4 lg:grid-cols-2">
      <div
        :for={{dom_id, chat_room} <- @streams.chat_rooms}
        id={dom_id}
        class="group rounded-2xl border border-border bg-card p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
      >
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-4">
            <div class="space-y-1">
              <.link
                id={"open-chat-room-#{chat_room.id}"}
                navigate={~p"/chat/#{chat_room.id}"}
                class="text-lg font-semibold text-foreground transition group-hover:text-primary"
              >
                {chat_room.title}
              </.link>
              <p class="text-sm text-muted-foreground">{last_message_preview(chat_room)}</p>
            </div>

            <div class="flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
              <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 font-medium text-muted-foreground">
                {agent_count(chat_room)} agents
              </span>
              <span
                :if={commander_name(chat_room)}
                class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-1 font-medium text-primary"
              >
                Commander: {commander_name(chat_room)}
              </span>
            </div>

            <div class="flex flex-wrap gap-2">
              <span
                :for={agent <- chat_room.agents}
                class="inline-flex items-center rounded-full border border-border bg-background px-2.5 py-1 text-xs font-medium text-foreground"
              >
                {agent.name}
              </span>
            </div>
          </div>

          <div class="flex gap-2">
            <.button
              id={"delete-chat-room-#{chat_room.id}"}
              phx-click="delete"
              phx-value-id={chat_room.id}
              data-confirm="Are you sure?"
            >
              Delete
            </.button>
          </div>
        </div>
      </div>

      <div
        id="chat-rooms-empty-state"
        class="hidden only:block rounded-2xl border border-dashed border-border bg-muted/30 p-10 text-center text-sm text-muted-foreground"
      >
        No chat rooms created yet.
      </div>
    </div>
  </div>
</Layouts.dashboard>
