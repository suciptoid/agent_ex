<Layouts.dashboard flash={@flash} current_scope={@current_scope}>
  <%= if @chat_room do %>
    <div class="flex flex-col h-full min-h-0">
      <%!-- Single-line title bar: Back | Title | Agent badges --%>
      <div class="flex items-center gap-3 px-1 pb-3 border-b border-border min-w-0">
        <.link
          navigate={~p"/chat"}
          class="flex-shrink-0 inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          <.icon name="hero-arrow-left" class="size-4" /> Back
        </.link>

        <h1 class="text-base font-semibold text-foreground truncate flex-1 min-w-0">
          {@chat_room.title}
        </h1>

        <div class="flex-shrink-0 flex flex-wrap gap-1.5">
          <span
            :for={chat_room_agent <- @chat_room.chat_room_agents}
            class={[
              "inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs font-medium",
              if(chat_room_agent.is_active,
                do: "border-primary/30 bg-primary/10 text-primary",
                else: "border-border bg-background text-muted-foreground"
              )
            ]}
          >
            <.icon name="hero-cpu-chip" class="size-3" />
            {chat_room_agent.agent.name}
            <span :if={chat_room_agent.is_active} class="text-[10px] opacity-70">active</span>
          </span>
        </div>
      </div>

      <%!-- Chat panel --%>
      <div class="flex flex-1 min-h-0 flex-col overflow-hidden rounded-xl border border-border bg-card shadow-sm mt-3">
        <%!-- Message list --%>
        <div
          id="chat-messages"
          phx-update="stream"
          class="flex-1 overflow-y-auto"
        >
          <div
            id="chat-messages-empty-state"
            class="hidden only:flex items-center justify-center h-full p-10 text-sm text-muted-foreground"
          >
            Send the first message to start the conversation.
          </div>

          <div
            :for={{dom_id, message} <- @streams.messages}
            id={dom_id}
            class={[
              "flex gap-2.5 px-3 py-2 group transition-colors",
              if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
            ]}
          >
            <%!-- Avatar --%>
            <div class={[
              "flex-shrink-0 flex size-7 items-center justify-center rounded-full text-xs font-semibold mt-0.5",
              if(user_message?(message),
                do: "bg-primary text-primary-foreground",
                else: "bg-muted text-muted-foreground"
              )
            ]}>
              <.icon name={message_icon(message)} class="size-3.5" />
            </div>

            <%!-- Content --%>
            <div class={[
              "flex-1 min-w-0 space-y-0.5",
              if(user_message?(message), do: "items-end", else: "items-start"),
              "flex flex-col"
            ]}>
              <div class={[
                "flex items-center gap-2 text-xs",
                if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
              ]}>
                <span class="font-semibold text-foreground">{speaker_name(message)}</span>
                <span class="text-muted-foreground/50">
                  {Calendar.strftime(message.inserted_at, "%H:%M")}
                </span>
                <%= if tool_message?(message) do %>
                  <span class="inline-flex items-center gap-1 rounded-full bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-600 dark:text-amber-400 border border-amber-500/20">
                    <.icon name="hero-wrench-screwdriver" class="size-3" /> tool
                  </span>
                <% end %>
                <%= if streaming_message?(message) do %>
                  <span class="inline-flex items-center gap-1 text-[10px] text-muted-foreground">
                    <span class="inline-block size-1.5 rounded-full bg-primary animate-pulse">
                    </span>
                    <%= if message.status == "requesting" do %>
                      thinking…
                    <% else %>
                      streaming…
                    <% end %>
                  </span>
                <% end %>
              </div>

              <%!-- Message body --%>
              <%= if tool_message?(message) do %>
                <div
                  class="w-full max-w-2xl"
                  id={"tool-msg-#{dom_id}"}
                  phx-hook=".ToolCallMessage"
                >
                  <button
                    data-toggle-btn
                    class="flex items-center gap-1.5 text-[11px] text-amber-600 dark:text-amber-400 hover:text-amber-700 dark:hover:text-amber-300 font-medium"
                  >
                    <.icon
                      name="hero-chevron-right"
                      class="size-3 transition-transform duration-200 data-[expanded=true]:rotate-90"
                    />
                    <span data-label>Show tool call</span>
                  </button>
                  <div
                    data-body
                    class="hidden mt-1 rounded-lg bg-amber-500/5 border border-amber-500/20 px-3 py-2 font-mono text-xs text-foreground leading-5"
                  >
                    <span class="whitespace-pre-wrap break-words">{message.content || ""}</span>
                  </div>
                </div>
              <% else %>
                <p class={[
                  "whitespace-pre-wrap break-words text-sm leading-6 text-foreground max-w-2xl",
                  if(user_message?(message),
                    do:
                      "rounded-2xl rounded-tr-sm bg-primary text-primary-foreground px-3 py-1.5",
                    else: ""
                  )
                ]}>
                  {message.content || ""}
                  <%= if streaming_message?(message) do %>
                    <span class="inline-block w-0.5 h-4 bg-foreground/40 ml-0.5 animate-pulse align-middle" />
                  <% end %>
                </p>
              <% end %>
            </div>
          </div>
        </div>

        <%!-- Message input --%>
        <div class="border-t border-border bg-background/80 px-3 py-2">
          <.form
            for={@message_form}
            id="chat-message-form"
            phx-change="validate"
            phx-submit="send"
            class="relative"
          >
            <.textarea
              field={@message_form[:content]}
              id="chat-message-input"
              rows="2"
              placeholder="Message… (Enter to send, Shift+Enter for new line)"
              phx-hook=".ChatInput"
              class="pr-12 resize-none"
            />
            <.button
              type="submit"
              phx-disable-with=""
              class="absolute bottom-2 right-2 flex size-8 items-center justify-center rounded-lg bg-primary p-0 text-primary-foreground shadow-sm transition-colors hover:bg-primary/90 disabled:opacity-60"
              aria-label="Send message"
            >
              <.icon name="hero-paper-airplane" class="size-4 text-current" />
            </.button>
          </.form>
        </div>
      </div>
    </div>
  <% end %>

  <%!-- Enter-to-send hook --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatInput">
    export default {
      mounted() {
        this.el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            const form = this.el.closest("form");
            if (form) form.dispatchEvent(new Event("submit", { bubbles: true, cancelable: true }));
          }
        });
      }
    }
  </script>

  <%!-- Tool call expand/collapse hook --%>
  <script :type={Phoenix.LiveView.ColocatedHook} name=".ToolCallMessage">
    export default {
      mounted() { this.init(); },
      updated() { this.init(); },
      init() {
        const el = this.el;
        const btn = el.querySelector("[data-toggle-btn]");
        const body = el.querySelector("[data-body]");
        const icon = btn && btn.querySelector("svg");
        const label = btn && btn.querySelector("[data-label]");
        if (!body || !btn) return;

        let expanded = false;

        const update = () => {
          if (expanded) {
            body.classList.remove("hidden");
            if (label) label.textContent = "Hide tool call";
            if (icon) icon.dataset.expanded = "true";
          } else {
            body.classList.add("hidden");
            if (label) label.textContent = "Show tool call";
            if (icon) icon.dataset.expanded = "false";
          }
        };

        btn.addEventListener("click", () => { expanded = !expanded; update(); });
        update();
      }
    }
  </script>
</Layouts.dashboard>
