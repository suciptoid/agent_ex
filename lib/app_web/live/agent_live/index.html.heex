<Layouts.dashboard flash={@flash} current_scope={@current_scope}>
  <div class="space-y-6">
    <div class="border-b border-border pb-6">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-2">
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Agents</h1>
          <p class="text-sm text-muted-foreground">
            Build reusable assistants that point at your providers and models.
          </p>
        </div>

        <%= if @providers == [] do %>
          <.link id="setup-provider-button" navigate={~p"/providers"}>
            <.button>Add Provider First</.button>
          </.link>
        <% else %>
          <.link id="new-agent-button" patch={~p"/agents/new"}>
            <.button>New Agent</.button>
          </.link>
        <% end %>
      </div>
    </div>

    <%= if @providers == [] do %>
      <div class="rounded-2xl border border-dashed border-border bg-muted/30 p-6 text-sm text-muted-foreground">
        Providers power each agent. Add one first, then come back to create your assistants.
      </div>
    <% end %>

    <%= if @live_action in [:new, :edit] do %>
      <.live_component
        module={AppWeb.AgentLive.FormComponent}
        id={@agent.id || :new}
        title={@page_title}
        action={@live_action}
        agent={@agent}
        providers={@providers}
        available_tools={@available_tools}
        current_scope={@current_scope}
        on_close={JS.patch(~p"/agents")}
      />
    <% end %>

    <div id="agents" phx-update="stream" class="grid gap-4 lg:grid-cols-2">
      <div
        :for={{dom_id, agent} <- @streams.agents}
        id={dom_id}
        data-agent-id={agent.id}
        class="rounded-2xl border border-border bg-card p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
      >
        <div class="flex items-start justify-between gap-4">
          <div class="space-y-2">
            <div>
              <h2 class="text-lg font-semibold text-foreground">{agent.name}</h2>
              <p class="text-sm text-muted-foreground">{provider_label(agent)}</p>
            </div>

            <div class="flex flex-wrap gap-2 text-xs text-muted-foreground">
              <span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-1 font-medium text-primary">
                {agent.model}
              </span>
              <span class="inline-flex items-center rounded-full bg-muted px-2.5 py-1 font-medium text-muted-foreground">
                {tools_summary(agent)}
              </span>
            </div>
          </div>

          <div class="flex shrink-0 items-center gap-2">
            <.link id={"edit-agent-#{agent.id}"} patch={~p"/agents/#{agent.id}/edit"}>
              <.button
                variant="outline"
                size="icon"
                title="Edit agent"
                aria-label="Edit agent"
              >
                <.icon name="hero-pencil-square" class="size-4" />
              </.button>
            </.link>
            <.button
              id={"delete-agent-#{agent.id}"}
              phx-click="delete"
              phx-value-id={agent.id}
              data-confirm="Are you sure?"
              variant="outline"
              size="icon"
              title="Delete agent"
              aria-label="Delete agent"
            >
              <.icon name="hero-trash" class="size-4" />
            </.button>
          </div>
        </div>
      </div>

      <div
        id="agents-empty-state"
        class="hidden rounded-2xl border border-dashed border-border bg-muted/30 p-10 text-center text-sm text-muted-foreground only:block"
      >
        No agents created yet.
      </div>
    </div>
  </div>
</Layouts.dashboard>
