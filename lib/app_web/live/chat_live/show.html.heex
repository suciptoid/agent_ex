<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
>
  <%= if @chat_room do %>
    <div class="flex h-full min-h-0 flex-col">
      <div class="border-b border-border px-4 pb-3 pt-4 sm:px-5 lg:px-6">
        <% agents_in_room = room_agents(@chat_room) %>
        <% unselected =
          Enum.reject(@available_agents, fn available_agent ->
            Enum.any?(@chat_room.chat_room_agents, &(&1.agent_id == available_agent.id))
          end) %>
        <div class="flex min-w-0 flex-wrap items-center gap-3">
          <.link
            navigate={~p"/chat"}
            class="inline-flex flex-shrink-0 items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
          >
            <.icon name="hero-arrow-left" class="size-4" /> Back
          </.link>

          <h1
            id="chat-room-title"
            class="min-w-0 flex-1 truncate text-base font-semibold text-foreground"
          >
            {@chat_room.title || ""}
          </h1>

          <div :if={@latest_message_id} class="w-full max-w-md flex-shrink-0">
            <AppWeb.ChatComponents.chat_agent_selector
              id="chat-agent-selector"
              class="justify-end"
              selected_agents={agents_in_room}
              unselected_agents={unselected}
              active_agent_id={active_agent_id(@chat_room)}
              set_active_event="set-active-agent"
              remove_event="remove-agent-from-room"
              add_event="add-agent-to-room"
              active_label="active"
            />
          </div>
        </div>
      </div>

      <div class="flex min-h-0 flex-1 flex-col px-4 pt-3 sm:px-5 sm:pt-4 lg:px-6">
        <div class="flex min-h-0 flex-1 flex-col overflow-hidden bg-card">
          <div class="flex-1 min-h-0">
            <div
              id="chat-messages"
              phx-update="stream"
              phx-hook=".ChatMessages"
              class="flex h-full min-h-full flex-1 flex-col-reverse overflow-y-auto"
            >
              <div
                id="chat-messages-empty-state"
                class="hidden h-full items-center justify-center p-10 text-sm text-muted-foreground only:flex"
              >
                Send the first message to start the conversation.
              </div>

              <div
                :for={{dom_id, message} <- @streams.messages}
                id={dom_id}
                class={[
                  "group flex gap-2.5 px-3 py-2 transition-colors",
                  if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                ]}
              >
                <div class={[
                  "mt-0.5 flex size-7 flex-shrink-0 items-center justify-center rounded-full text-xs font-semibold",
                  if(user_message?(message),
                    do: "bg-primary text-primary-foreground",
                    else: "bg-muted text-muted-foreground"
                  )
                ]}>
                  <.icon name={message_icon(message)} class="size-3.5" />
                </div>

                <div class={[
                  "flex min-w-0 flex-1 flex-col space-y-1",
                  if(user_message?(message), do: "items-end", else: "items-start")
                ]}>
                  <% thinking = message_thinking(message) %>
                  <% responses = tool_responses(message) %>
                  <% estimated_cost = estimated_cost_label(message) %>

                  <div class={[
                    "flex items-center gap-2 text-xs",
                    if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                  ]}>
                    <span class="font-semibold text-foreground">{speaker_name(message)}</span>
                    <span class="text-muted-foreground/50">
                      {Calendar.strftime(message.inserted_at, "%H:%M")}
                    </span>

                    <%= if responses != [] do %>
                      <span class="inline-flex items-center gap-1 rounded-full border border-amber-500/20 bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-600 dark:text-amber-400">
                        <.icon name="hero-wrench-screwdriver" class="size-3" /> tools
                      </span>
                    <% end %>

                    <%= if streaming_message?(message) do %>
                      <span class="inline-flex items-center gap-1 text-[10px] text-muted-foreground">
                        <span class="inline-block size-1.5 rounded-full bg-primary animate-pulse">
                        </span>
                        <%= if message.status == :pending do %>
                          thinking…
                        <% else %>
                          streaming…
                        <% end %>
                      </span>
                    <% end %>

                    <div
                      :if={assistant_message?(message)}
                      class="ml-auto flex items-center gap-1.5"
                    >
                      <span
                        :if={estimated_cost}
                        id={"message-cost-#{message.id}"}
                        class="pointer-events-none inline-flex items-center text-[10px] text-muted-foreground opacity-0 transition group-hover:opacity-100"
                      >
                        {estimated_cost}
                      </span>

                      <button
                        :if={
                          regeneratable_message?(message, @latest_message_id) and
                            not @streaming_active?
                        }
                        id={"regenerate-message-#{message.id}"}
                        type="button"
                        phx-click="regenerate"
                        phx-value-id={message.id}
                        title={regenerate_label(message)}
                        aria-label={regenerate_label(message)}
                        class="inline-flex size-7 items-center justify-center rounded-full text-muted-foreground opacity-0 transition hover:bg-muted hover:text-foreground group-hover:opacity-100"
                      >
                        <.icon name="hero-arrow-path" class="size-4" />
                      </button>
                    </div>
                  </div>

                  <%= if thinking not in [nil, ""] do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-thinking-#{message.id}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        open={thinking_default_expanded?(message)}
                        class="overflow-hidden rounded-lg border border-sky-500/20 bg-sky-500/5"
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class="flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium text-sky-700 hover:text-sky-800 dark:text-sky-300 dark:hover:text-sky-200 [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5"
                        >
                          <span>Thinking</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>{thinking}</span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= for {tool_response, index} <- Enum.with_index(responses) do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-tool-response-#{message.id}-#{index}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        class={
                          "overflow-hidden rounded-lg border transition-colors " <>
                            if(tool_response_error?(tool_response),
                              do: "border-rose-500/20 bg-rose-500/5",
                              else: "border-amber-500/20 bg-amber-500/5"
                            )
                        }
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class={
                            "flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5 " <>
                              if(tool_response_error?(tool_response),
                                do:
                                  "text-rose-600 hover:text-rose-700 dark:text-rose-300 dark:hover:text-rose-200",
                                else:
                                  "text-amber-600 hover:text-amber-700 dark:text-amber-400 dark:hover:text-amber-300"
                              )
                          }
                        >
                          <.icon
                            :if={tool_response_running?(tool_response)}
                            name="hero-arrow-path"
                            class="size-3 shrink-0 animate-spin"
                          />
                          <span class="shrink-0">Response</span>
                          <span class="truncate">{tool_response_label(tool_response)}</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>
                            {tool_response_content(tool_response)}
                          </span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= if message_has_content?(message) do %>
                    <%= if user_message?(message) do %>
                      <p
                        class="max-w-2xl whitespace-pre-line break-words rounded-2xl rounded-tr-sm bg-primary px-3 py-1.5 text-sm leading-6 text-primary-foreground"
                        phx-no-format
                      >{message.content}</p>
                    <% else %>
                      <div
                        class="prose prose-sm prose-foreground max-w-2xl dark:prose-invert prose-pre:bg-muted prose-pre:text-foreground prose-headings:text-foreground prose-p:text-foreground prose-li:text-foreground prose-strong:text-foreground prose-em:text-foreground"
                        phx-no-format
                      >{raw(render_markdown(message.content))}</div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="relative mt-3">
            <button
              id="scroll-to-bottom-btn"
              class="absolute -top-8 left-1/2 z-10 hidden -translate-x-1/2 items-center gap-1.5 rounded-full border border-border bg-background/95 px-3 py-1 text-xs font-medium text-muted-foreground shadow-md backdrop-blur transition-all hover:bg-muted hover:text-foreground"
              aria-label="Scroll to bottom"
            >
              <.icon name="hero-arrow-down" class="size-3.5" /> Scroll to bottom
            </button>
            <.form
              for={@message_form}
              id="chat-message-form"
              phx-change="validate"
              phx-submit="send"
              data-streaming={to_string(@streaming_active?)}
              class="relative"
            >
              <.textarea
                field={@message_form[:content]}
                id="chat-message-input"
                rows="2"
                placeholder="Message… (Enter to send, Shift+Enter for new line)"
                phx-hook=".ChatInput"
                class="min-h-24 resize-none rounded-2xl px-4 py-4 pr-14"
              />
              <button
                id="chat-message-submit"
                type={if @streaming_active?, do: "button", else: "submit"}
                phx-click={if @streaming_active?, do: "cancel-stream", else: nil}
                class={[
                  "group absolute bottom-3 right-3 flex size-9 items-center justify-center rounded-xl bg-primary p-0 text-primary-foreground shadow-sm transition-colors hover:bg-primary/90",
                  if(@streaming_active?, do: "hover:bg-destructive", else: "")
                ]}
                aria-label={if @streaming_active?, do: "Stop generating", else: "Send message"}
                title={if @streaming_active?, do: "Stop generating", else: "Send message"}
              >
                <%= if @streaming_active? do %>
                  <span class="relative flex size-4 items-center justify-center">
                    <.icon
                      name="hero-arrow-path"
                      class="size-4 animate-spin text-current transition-opacity group-hover:opacity-0"
                    />
                    <.icon
                      name="hero-stop"
                      class="absolute size-4 text-current opacity-0 transition-opacity group-hover:opacity-100"
                    />
                  </span>
                <% else %>
                  <.icon
                    name="hero-paper-airplane"
                    class="size-4 text-current transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                  />
                <% end %>
              </button>
            </.form>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatInput">
    export default {
      mounted() {
        this.el.addEventListener("keydown", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            const form = this.el.closest("form");
            if (!form || form.dataset.streaming === "true") return;

            if (typeof form.requestSubmit === "function") {
              form.requestSubmit();
            } else {
              form.dispatchEvent(new Event("submit", { bubbles: true, cancelable: true }));
            }
          }
        });
      }
    }
  </script>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".CollapsibleSection">
    export default {
      mounted() {
        this.userToggled = false;
        this.unbind();
        this.bind();
        this.applyDefault();
      },

      updated() {
        this.unbind();
        this.bind();
        if (!this.userToggled) {
          this.applyDefault();
        } else {
          this.render();
        }
      },

      destroyed() {
        this.unbind();
      },

      bind() {
        this.btn = this.el.querySelector("[data-toggle-btn]");
        this.body = this.el.querySelector("[data-body]");
        this.icon = this.btn && this.btn.querySelector("svg");
        this.label = this.btn && this.btn.querySelector("[data-label]");

        if (!this.btn || !this.body) return;

        this.onClick = () => {
          this.userToggled = true;
          this.expanded = !this.expanded;
          this.render();
        };

        this.btn.addEventListener("click", this.onClick);
      },

      unbind() {
        if (this.btn && this.onClick) {
          this.btn.removeEventListener("click", this.onClick);
        }
      },

      applyDefault() {
        this.expanded = this.el.dataset.defaultExpanded === "true";
        this.render();
      },

      render() {
        if (!this.btn || !this.body) return;

        const expandedLabel = this.el.dataset.labelExpanded || "Hide details";
        const collapsedLabel = this.el.dataset.labelCollapsed || "Show details";
        const scrollContainer = document.getElementById("chat-messages");
        const previousMetrics = scrollContainer ? {
          scrollTop: scrollContainer.scrollTop,
          scrollHeight: scrollContainer.scrollHeight
        } : null;

        this.btn.setAttribute("aria-expanded", this.expanded ? "true" : "false");

        if (this.expanded) {
          this.body.classList.remove("hidden");
          if (this.label) this.label.textContent = expandedLabel;
          if (this.icon) this.icon.style.transform = "rotate(90deg)";
        } else {
          this.body.classList.add("hidden");
          if (this.label) this.label.textContent = collapsedLabel;
          if (this.icon) this.icon.style.transform = "rotate(0deg)";
        }

        this.el.dispatchEvent(new CustomEvent("chat:content-resized", {
          bubbles: true,
          detail: previousMetrics
        }));
      }
    }
  </script>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatMessages">
    export default {
      mounted() {
        this.isNearLatest = true
        this._programmaticScroll = false
        this.scrollBtn = document.getElementById("scroll-to-bottom-btn")

        this.onScroll = () => {
          if (this._programmaticScroll) return
          this.checkScrollPosition()
        }

        this.onContentResized = (event) => {
          if (event.detail) {
            this.previousScrollTop = event.detail.scrollTop
            this.previousScrollHeight = event.detail.scrollHeight
          } else {
            this.previousScrollTop = this.el.scrollTop
            this.previousScrollHeight = this.el.scrollHeight
          }
          this.restoreScrollPosition()
        }

        this.onScrollButtonClick = () => {
          this.isNearLatest = true
          this.scrollToLatest({ behavior: "smooth" })
        }

        this.el.addEventListener("scroll", this.onScroll)
        this.el.addEventListener("chat:content-resized", this.onContentResized)
        if (this.scrollBtn) {
          this.scrollBtn.addEventListener("click", this.onScrollButtonClick)
        }

        this.handleEvent("scroll-to-bottom", () => {
          this.isNearLatest = true
          window.requestAnimationFrame(() => this.scrollToLatest())
        })

        window.requestAnimationFrame(() => {
          this.scrollToLatest()
          this.updateButtonVisibility()
        })
      },

      beforeUpdate() {
        this.previousScrollTop = this.el.scrollTop
        this.previousScrollHeight = this.el.scrollHeight
      },

      updated() {
        this.restoreScrollPosition()
      },

      destroyed() {
        this.el.removeEventListener("scroll", this.onScroll)
        this.el.removeEventListener("chat:content-resized", this.onContentResized)
        if (this.scrollBtn) {
          this.scrollBtn.removeEventListener("click", this.onScrollButtonClick)
        }
      },

      checkScrollPosition() {
        const threshold = Math.max(this.el.clientHeight * 0.15, 40)
        this.isNearLatest = this.el.scrollTop <= threshold
        this.updateButtonVisibility()
      },

      updateButtonVisibility() {
        if (this.scrollBtn) {
          this.scrollBtn.style.display = this.isNearLatest ? "none" : "flex"
        }
      },

      restoreScrollPosition() {
        this._programmaticScroll = true
        window.requestAnimationFrame(() => {
          if (this.isNearLatest) {
            this.scrollToLatest()
          } else if (
            typeof this.previousScrollTop === "number" &&
            typeof this.previousScrollHeight === "number"
          ) {
            const heightDelta = this.el.scrollHeight - this.previousScrollHeight
            this.el.scrollTop = Math.max(0, this.previousScrollTop + heightDelta)
          }

          this.updateButtonVisibility()

          requestAnimationFrame(() => {
            this._programmaticScroll = false
          })
        })
      },

      scrollToLatest(options = {}) {
        this.el.scrollTo({
          top: 0,
          behavior: options.behavior || "auto"
        })
        this.isNearLatest = true
        this.updateButtonVisibility()
      }
    }
  </script>
</Layouts.dashboard>
