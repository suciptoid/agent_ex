<%!-- Top bar with login indicator --%>
<div class="fixed top-0 left-0 right-0 z-50">
  <div class="border-b border-border/50 bg-background/80 backdrop-blur-xl">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3">
        <svg viewBox="0 0 71 48" class="h-8" aria-hidden="true">
          <path
            d="m26.371 33.477-.552-.1c-3.92-.729-6.397-3.1-7.57-6.829-.733-2.324.597-4.035 3.035-4.148 1.995-.092 3.362 1.055 4.57 2.39 1.557 1.72 2.984 3.558 4.514 5.305 2.202 2.515 4.797 4.136 8.347 3.634 3.183-.448 5.958-1.725 8.371-3.828.363-.316.761-.592 1.144-.886l-.241-.284c-2.027.63-4.093.841-6.205.735-3.195-.16-6.24-.828-8.964-2.582-2.486-1.601-4.319-3.746-5.19-6.611-.704-2.315.736-3.934 3.135-3.6.948.133 1.746.56 2.463 1.165.583.493 1.143 1.015 1.738 1.493 2.8 2.25 6.712 2.375 10.265-.068-5.842-.026-9.817-3.24-13.308-7.313-1.366-1.594-2.7-3.216-4.095-4.785-2.698-3.036-5.692-5.71-9.79-6.623C12.8-.623 7.745.14 2.893 2.361 1.926 2.804.997 3.319 0 4.149c.494 0 .763.006 1.032 0 2.446-.064 4.28 1.023 5.602 3.024.962 1.457 1.415 3.104 1.761 4.798.513 2.515.247 5.078.544 7.605.761 6.494 4.08 11.026 10.26 13.346 2.267.852 4.591 1.135 7.172.555ZM10.751 3.852c-.976.246-1.756-.148-2.56-.962 1.377-.343 2.592-.476 3.897-.528-.107.848-.607 1.306-1.336 1.49Zm32.002 37.924c-.085-.626-.62-.901-1.04-1.228-1.857-1.446-4.03-1.958-6.333-2-1.375-.026-2.735-.128-4.031-.61-.595-.22-1.26-.505-1.244-1.272.015-.78.693-1 1.31-1.184.505-.15 1.026-.247 1.6-.382-1.46-.936-2.886-1.065-4.787-.3-2.993 1.202-5.943 1.06-8.926-.017-1.684-.608-3.179-1.563-4.735-2.408l-.043.03a2.96 2.96 0 0 0 .04-.029c-.038-.117-.107-.12-.197-.054l.122.107c1.29 2.115 3.034 3.817 5.004 5.271 3.793 2.8 7.936 4.471 12.784 3.73A66.714 66.714 0 0 1 37 40.877c1.98-.16 3.866.398 5.753.899Zm-9.14-30.345c-.105-.076-.206-.266-.42-.069 1.745 2.36 3.985 4.098 6.683 5.193 4.354 1.767 8.773 2.07 13.293.51 3.51-1.21 6.033-.028 7.343 3.38.19-3.955-2.137-6.837-5.843-7.401-2.084-.318-4.01.373-5.962.94-5.434 1.575-10.485.798-15.094-2.553Zm27.085 15.425c.708.059 1.416.123 2.124.185-1.6-1.405-3.55-1.517-5.523-1.404-3.003.17-5.167 1.903-7.14 3.972-1.739 1.824-3.31 3.87-5.903 4.604.043.078.054.117.066.117.35.005.699.021 1.047.005 3.768-.17 7.317-.965 10.14-3.7.89-.86 1.685-1.817 2.544-2.71.716-.746 1.584-1.159 2.645-1.07Zm-8.753-4.67c-2.812.246-5.254 1.409-7.548 2.943-1.766 1.18-3.654 1.738-5.776 1.37-.374-.066-.75-.114-1.124-.17l-.013.156c.135.07.265.151.405.207.354.14.702.308 1.07.395 4.083.971 7.992.474 11.516-1.803 2.221-1.435 4.521-1.707 7.013-1.336.252.038.503.083.756.107.234.022.479.255.795.003-2.179-1.574-4.526-2.096-7.094-1.872Zm-10.049-9.544c1.475.051 2.943-.142 4.486-1.059-.452.04-.643.04-.827.076-2.126.424-4.033-.04-5.733-1.383-.623-.493-1.257-.974-1.889-1.457-2.503-1.914-5.374-2.555-8.514-2.5.05.154.054.26.108.315 3.417 3.455 7.371 5.836 12.369 6.008Zm24.727 17.731c-2.114-2.097-4.952-2.367-7.578-.537 1.738.078 3.043.632 4.101 1.728.374.388.763.768 1.182 1.106 1.6 1.29 4.311 1.352 5.896.155-1.861-.726-1.861-.726-3.601-2.452Zm-21.058 16.06c-1.858-3.46-4.981-4.24-8.59-4.008a9.667 9.667 0 0 1 2.977 1.39c.84.586 1.547 1.311 2.243 2.055 1.38 1.473 3.534 2.376 4.962 2.07-.656-.412-1.238-.848-1.592-1.507Zm17.29-19.32c0-.023.001-.045.003-.068l-.006.006.006-.006-.036-.004.021.018.012.053Zm-20 14.744a7.61 7.61 0 0 0-.072-.041.127.127 0 0 0 .015.043c.005.008.038 0 .058-.002Zm-.072-.041-.008-.034-.008.01.008-.01-.022-.006.005.026.024.014Z"
            fill="#FD4F00"
          />
        </svg>
        <span class="text-lg font-semibold tracking-tight">AgentEx</span>
      </div>

      <div class="flex items-center gap-4">
        <Layouts.theme_toggle />

        <%= if @current_scope && @current_scope.user do %>
          <div class="flex items-center gap-3">
            <.link
              navigate={~p"/dashboard"}
              class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow transition hover:bg-primary/90 hover:shadow-md"
            >
              <.icon name="hero-rectangle-stack" class="size-4" /> Dashboard
            </.link>
            <div class="flex items-center gap-2">
              <span class="relative flex size-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75">
                </span>
                <span class="relative inline-flex size-2.5 rounded-full bg-emerald-500"></span>
              </span>
              <span class="text-sm font-medium text-foreground">{@current_scope.user.email}</span>
            </div>
          </div>
        <% else %>
          <.link
            navigate={~p"/users/log-in"}
            class="inline-flex items-center gap-2 rounded-lg border border-border bg-background px-4 py-2 text-sm font-semibold text-foreground shadow-sm transition hover:bg-accent hover:text-foreground"
          >
            Sign In
          </.link>
          <.link
            navigate={~p"/users/register"}
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground shadow transition hover:bg-primary/90 hover:shadow-md"
          >
            Get Started
          </.link>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%!-- Hero Section --%>
<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <%!-- Background gradient --%>
  <div class="absolute inset-0 bg-gradient-to-b from-orange-50/50 via-transparent to-transparent dark:from-orange-950/20 dark:via-transparent">
  </div>

  <%!-- Decorative grid pattern --%>
  <div class="absolute inset-0 opacity-[0.015] dark:opacity-[0.025]" aria-hidden="true">
    <div
      class="h-full w-full"
      style="background-image: radial-gradient(circle, #FD4F00 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
  </div>

  <%!-- Glowing orbs --%>
  <div
    class="absolute -top-40 -right-40 h-[500px] w-[500px] rounded-full bg-orange-400/20 blur-3xl dark:bg-orange-600/10"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-rose-400/20 blur-3xl dark:bg-rose-600/10"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-orange-200 bg-orange-50 px-4 py-1.5 text-sm font-medium text-orange-700 dark:border-orange-800/50 dark:bg-orange-950/50 dark:text-orange-300">
        <span class="relative flex size-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-orange-400 opacity-75">
          </span>
          <span class="relative inline-flex size-2 rounded-full bg-orange-500"></span>
        </span>
        Multi-Agent AI Workspace
      </div>

      <h1 class="mt-8 text-5xl font-extrabold leading-[1.1] tracking-tighter text-foreground sm:text-6xl lg:text-7xl">
        Build, orchestrate, and
        <span class="bg-gradient-to-r from-orange-500 via-rose-500 to-pink-500 bg-clip-text text-transparent">
          converse
        </span>
        with AI agents
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-muted-foreground">
        A powerful platform for creating AI agents, connecting them to tools, and running multi-agent conversations. Orchestrate complex workflows with seamless handoffs and real-time streaming.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
        <%= if @current_scope && @current_scope.user do %>
          <.link
            navigate={~p"/dashboard"}
            class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5"
          >
            <.icon name="hero-rectangle-stack" class="size-5" /> Open Dashboard
          </.link>
        <% else %>
          <.link
            navigate={~p"/users/register"}
            class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5"
          >
            Start Building — It's Free <.icon name="hero-arrow-right" class="size-5" />
          </.link>
          <.link
            navigate={~p"/users/log-in"}
            class="inline-flex items-center gap-2 rounded-xl border border-border bg-background px-8 py-3.5 text-base font-semibold text-foreground shadow-sm transition-all hover:bg-accent hover:text-foreground hover:-translate-y-0.5"
          >
            Sign In
          </.link>
        <% end %>
      </div>
    </div>

    <%!-- Hero visual --%>
    <div class="relative mx-auto mt-16 max-w-5xl">
      <div class="overflow-hidden rounded-2xl border border-border/50 bg-card shadow-2xl">
        <div class="flex items-center gap-2 border-b border-border/50 px-4 py-3">
          <div class="size-3 rounded-full bg-red-400"></div>
          <div class="size-3 rounded-full bg-yellow-400"></div>
          <div class="size-3 rounded-full bg-green-400"></div>
          <span class="ml-2 text-xs text-muted-foreground">agent.sukacipta.com/chat</span>
        </div>
        <div class="bg-gradient-to-br from-muted/30 to-muted/10 p-6 sm:p-8">
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                <.icon name="hero-user" class="size-4" />
              </div>
              <div class="rounded-2xl rounded-tl-sm bg-background px-4 py-3 shadow-sm">
                <p class="text-sm text-foreground">
                  Research the latest Phoenix 1.8 features and create a summary
                </p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="flex size-8 shrink-0 items-center justify-center rounded-full bg-emerald-500/10 text-emerald-500">
                <.icon name="hero-cpu-chip" class="size-4" />
              </div>
              <div class="w-full space-y-3">
                <div class="rounded-2xl rounded-tl-sm bg-background px-4 py-3 shadow-sm">
                  <p class="text-sm font-medium text-foreground">Research Agent</p>
                  <p class="mt-1 text-sm text-muted-foreground">
                    I'll help with that! Let me search for the latest Phoenix 1.8 features...
                  </p>
                  <div class="mt-2 flex items-center gap-1.5">
                    <span class="chat-streaming-dot inline-flex size-1.5 rounded-full bg-orange-500">
                    </span>
                    <span class="chat-streaming-dot inline-flex size-1.5 rounded-full bg-orange-500">
                    </span>
                    <span class="chat-streaming-dot inline-flex size-1.5 rounded-full bg-orange-500">
                    </span>
                  </div>
                </div>
                <div class="flex items-center gap-2 rounded-lg border border-border/50 bg-muted/50 px-3 py-2">
                  <.icon
                    name="hero-document-magnifying-glass"
                    class="size-3.5 text-muted-foreground"
                  />
                  <span class="text-xs text-muted-foreground">
                    web_fetch → hexdocs.pm/phoenix/overview
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <%!-- Glow behind the visual --%>
      <div
        class="absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-r from-orange-500/10 via-rose-500/10 to-pink-500/10 blur-2xl"
        aria-hidden="true"
      >
      </div>
    </div>
  </div>
</section>

<%!-- Features Section --%>
<section class="relative border-t border-border/50 bg-muted/20 py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
        Everything you need to
        <span class="bg-gradient-to-r from-orange-500 to-rose-500 bg-clip-text text-transparent">
          orchestrate
        </span>
        AI agents
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        From agent creation to production deployment, our platform provides a complete toolkit for building intelligent, multi-agent workflows.
      </p>
    </div>

    <div class="mx-auto mt-16 grid max-w-5xl gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <%!-- Feature 1 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-primary/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-orange-500/10 text-orange-500 transition-colors group-hover:bg-orange-500/15">
          <.icon name="hero-cpu-chip" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Multi-Agent Orchestration</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Create and manage multiple AI agents in a single conversation. Agents can hand off tasks, delegate sub-tasks, and collaborate seamlessly.
        </p>
      </div>

      <%!-- Feature 2 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-emerald-500/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-emerald-500/10 text-emerald-500 transition-colors group-hover:bg-emerald-500/15">
          <.icon name="hero-chat-bubble-left-right" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Real-Time Streaming</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Watch AI responses stream token-by-token with smooth animations. Background streaming ensures conversations continue even when you navigate away.
        </p>
      </div>

      <%!-- Feature 3 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-blue-500/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-blue-500/10 text-blue-500 transition-colors group-hover:bg-blue-500/15">
          <.icon name="hero-wrench-screwdriver" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Extensible Tool System</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Connect agents to web fetching, shell execution, custom HTTP tools, or create your own. Agents can call tools, receive results, and continue reasoning.
        </p>
      </div>

      <%!-- Feature 4 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-violet-500/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-violet-500/10 text-violet-500 transition-colors group-hover:bg-violet-500/15">
          <.icon name="hero-rectangle-stack" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Organizations & Teams</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Multi-tenant workspace with role-based access control. All resources are organization-scoped with easy switching between workspaces.
        </p>
      </div>

      <%!-- Feature 5 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-amber-500/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-amber-500/10 text-amber-500 transition-colors group-hover:bg-amber-500/15">
          <.icon name="hero-signal" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Telegram Integration</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Bridge external Telegram chats into your workspace. Automatic channel creation, typing indicators, and real-time sync between Telegram and web.
        </p>
      </div>

      <%!-- Feature 6 --%>
      <div class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-pink-500/20">
        <div class="mb-4 inline-flex size-11 items-center justify-center rounded-xl bg-pink-500/10 text-pink-500 transition-colors group-hover:bg-pink-500/15">
          <.icon name="hero-arrow-path-rounded" class="size-6" />
        </div>
        <h3 class="text-lg font-semibold text-foreground">Context Management</h3>
        <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
          Automatic context compaction when conversations approach limits. Reasoning effort controls for models that support adjustable thinking depth.
        </p>
      </div>
    </div>
  </div>
</section>

<%!-- CTA Section --%>
<section class="relative overflow-hidden py-24 sm:py-32">
  <div class="absolute inset-0 bg-gradient-to-br from-orange-500/5 via-transparent to-rose-500/5 dark:from-orange-500/10 dark:via-transparent dark:to-rose-500/10">
  </div>
  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
      Ready to build your AI agents?
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-muted-foreground">
      Join the growing community of developers using AgentEx to craft powerful multi-agent workflows.
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <%= if @current_scope && @current_scope.user do %>
        <.link
          navigate={~p"/dashboard"}
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5"
        >
          Go to Dashboard <.icon name="hero-arrow-right" class="size-5" />
        </.link>
      <% else %>
        <.link
          navigate={~p"/users/register"}
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-3.5 text-base font-semibold text-primary-foreground shadow-lg transition-all hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5"
        >
          Get Started Free <.icon name="hero-arrow-right" class="size-5" />
        </.link>
      <% end %>
    </div>
  </div>
</section>

<%!-- Footer --%>
<footer class="border-t border-border/50 bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <div class="flex items-center gap-3">
