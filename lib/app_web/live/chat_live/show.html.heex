<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
  sidebar_organizations={@sidebar_organizations}
>
  <%= if @chat_room do %>
    <% agents_in_room = room_agents(@chat_room) %>
    <% unselected =
      Enum.reject(@available_agents, fn available_agent ->
        Enum.any?(@chat_room.chat_room_agents, &(&1.agent_id == available_agent.id))
      end) %>
    <div
      id="chat-room-shell"
      class="relative flex h-full min-h-0 overflow-hidden"
      phx-hook=".ChatAgentSidebar"
      data-agent-sidebar-open="false"
    >
      <div
        id="chat-room-layout"
        class="relative flex min-h-0 flex-1 flex-col"
        style="--chat-composer-offset: var(--chat-room-layout-composer-offset, 12rem);"
      >
        <%= if @pending_channel do %>
          <div class="pointer-events-none absolute inset-x-0 top-3 z-40 px-4 sm:px-5 lg:px-6">
            <div class="mx-auto flex w-full max-w-4xl justify-center">
              <div class="pointer-events-auto flex w-full max-w-3xl flex-col gap-3 rounded-2xl border border-amber-300/70 bg-amber-50/95 px-4 py-3 shadow-lg shadow-amber-900/10 backdrop-blur dark:border-amber-800/80 dark:bg-amber-950/90 sm:flex-row sm:items-center sm:justify-between">
                <div class="flex min-w-0 items-start gap-3 text-sm text-amber-900 dark:text-amber-200">
                  <span class="mt-0.5 inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-amber-500/15 text-amber-600 dark:text-amber-300">
                    <.icon name="hero-exclamation-triangle" class="size-4" />
                  </span>
                  <div class="min-w-0 space-y-1">
                    <p class="font-semibold tracking-tight">Pending approval</p>
                    <p class="leading-5 text-amber-800/90 dark:text-amber-200/85">
                      External user
                      <strong>
                        {@pending_channel.external_username || @pending_channel.external_user_id}
                      </strong>
                      is waiting for an organization member mapping before replies can continue.
                    </p>
                  </div>
                </div>

                <form
                  id="approve-channel-form"
                  phx-submit="approve-channel"
                  class="flex flex-col gap-2 sm:min-w-[21rem] sm:flex-row"
                >
                  <select
                    id="approve-channel-user-select"
                    name="user_id"
                    class="h-10 min-w-0 flex-1 rounded-xl border border-amber-300/80 bg-background/95 px-3 text-sm shadow-sm outline-none transition focus:border-amber-400 focus:ring-2 focus:ring-amber-300/60 dark:border-amber-800 dark:bg-background"
                  >
                    <option value="">Map to user...</option>
                    <%= for user <- @organization_users do %>
                      <option value={user.id}>{user.name || user.email || "Unnamed"}</option>
                    <% end %>
                  </select>
                  <div class="flex gap-2">
                    <.button id="approve-channel-button" type="submit" class="flex-1 sm:flex-none">
                      Approve
                    </.button>
                    <.button
                      id="reject-channel-button"
                      type="button"
                      variant="destructive"
                      phx-click="reject-channel"
                      data-confirm="Reject this channel? Messages will be blocked."
                      class="flex-1 sm:flex-none"
                    >
                      Reject
                    </.button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% end %>

        <button
          id="chat-agent-sidebar-toggle"
          type="button"
          data-agent-sidebar-toggle
          aria-expanded="false"
          aria-controls="chat-agent-sidebar"
          class="absolute right-4 top-4 z-30 inline-flex h-9 items-center gap-2 rounded-lg border border-border bg-background/90 px-3 text-xs font-medium text-muted-foreground shadow-sm backdrop-blur transition hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring sm:right-5 lg:right-6"
        >
          <.icon name="hero-cpu-chip" class="size-3.5" />
          <span class="hidden sm:inline">Agents</span>
        </button>

        <div class="flex min-h-0 flex-1 flex-col overflow-hidden bg-card">
          <div class="flex-1 min-h-0">
            <div
              id="chat-messages"
              phx-update="stream"
              phx-hook=".ChatMessages"
              data-messages-revision={@messages_revision}
              class={[
                "flex h-full min-h-full w-full flex-1 flex-col overflow-y-auto overscroll-contain pb-[var(--chat-composer-offset)]",
                @pending_channel && "pt-28 sm:pt-24"
              ]}
            >
              <div
                id="chat-messages-empty-state"
                class="mx-auto hidden h-full w-full max-w-4xl items-center justify-center px-4 py-10 text-center text-sm text-muted-foreground only:flex sm:px-5 lg:px-6"
              >
                Send the first message to start the conversation.
              </div>

              <div
                :for={{dom_id, message} <- @streams.messages}
                id={dom_id}
                class={[
                  "group mx-auto flex w-full max-w-4xl gap-2.5 px-4 py-2 transition-colors sm:px-5 lg:px-6",
                  if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                ]}
              >
                <div class={[
                  "mt-0.5 flex size-7 flex-shrink-0 items-center justify-center rounded-full text-xs font-semibold",
                  if(user_message?(message),
                    do: "bg-primary text-primary-foreground",
                    else: "bg-muted text-muted-foreground"
                  )
                ]}>
                  <.icon name={message_icon(message)} class="size-3.5" />
                </div>

                <div class={[
                  "flex min-w-0 flex-1 flex-col space-y-1",
                  if(user_message?(message), do: "items-end", else: "items-start")
                ]}>
                  <% thinking = message_thinking(message) %>
                  <% tool_entries = assistant_tool_entries(message) %>
                  <% estimated_cost = estimated_cost_label(message) %>

                  <div class={[
                    "flex items-center gap-2 text-xs",
                    if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                  ]}>
                    <span class="font-semibold text-foreground">{speaker_name(message)}</span>
                    <span class="text-muted-foreground/50">
                      {Calendar.strftime(message.inserted_at, "%H:%M")}
                    </span>

                    <div
                      :if={assistant_message?(message)}
                      class="ml-auto flex items-center gap-1.5"
                    >
                      <span
                        :if={estimated_cost}
                        id={"message-cost-#{message.id}"}
                        class="pointer-events-none inline-flex items-center text-[10px] text-muted-foreground opacity-0 transition group-hover:opacity-100"
                      >
                        {estimated_cost}
                      </span>

                      <button
                        :if={
                          regeneratable_message?(message, @latest_message_id) and
                            not @streaming_active?
                        }
                        id={"regenerate-message-#{message.id}"}
                        type="button"
                        phx-click="regenerate"
                        phx-value-id={message.id}
                        title={regenerate_label(message)}
                        aria-label={regenerate_label(message)}
                        class="inline-flex size-7 items-center justify-center rounded-full text-muted-foreground opacity-0 transition hover:bg-muted hover:text-foreground group-hover:opacity-100"
                      >
                        <.icon name="hero-arrow-path" class="size-4" />
                      </button>
                    </div>
                  </div>

                  <%= if thinking not in [nil, ""] do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-thinking-#{message.id}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        open={thinking_default_expanded?(message)}
                        class="overflow-hidden rounded-lg border border-secondary bg-secondary/70 text-secondary-foreground"
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class="flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium text-secondary-foreground/80 hover:text-secondary-foreground [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5"
                        >
                          <.icon name="hero-light-bulb" class="size-3 shrink-0" />
                          <span>Thinking</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>{thinking}</span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= for {tool_entry, index} <- Enum.with_index(tool_entries) do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-tool-#{message.id}-#{index}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        class={
                          "overflow-hidden rounded-lg border transition-colors " <>
                            if(tool_entry_error?(tool_entry),
                              do: "border-rose-500/20 bg-rose-500/5",
                              else: "border-secondary bg-secondary/70 text-secondary-foreground"
                            )
                        }
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class={
                            "flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5 " <>
                              if(tool_entry_error?(tool_entry),
                                do:
                                  "text-rose-600 hover:text-rose-700 dark:text-rose-300 dark:hover:text-rose-200",
                                else:
                                  "text-secondary-foreground/80 hover:text-secondary-foreground"
                              )
                          }
                        >
                          <.icon
                            :if={tool_entry_running?(tool_entry)}
                            name="hero-arrow-path"
                            class="size-3 shrink-0 animate-spin"
                          />
                          <.icon
                            :if={not tool_entry_running?(tool_entry)}
                            name="hero-wrench-screwdriver"
                            class="size-3 shrink-0"
                          />
                          <span class="truncate">{tool_entry_label(tool_entry)}</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>
                            {tool_entry_content(tool_entry)}
                          </span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= if message_has_content?(message) do %>
                    <%= if user_message?(message) do %>
                      <p
                        class="max-w-2xl whitespace-pre-line break-words rounded-2xl rounded-tr-sm bg-primary px-3 py-1.5 text-sm leading-6 text-primary-foreground"
                        phx-no-format
                      >{message.content}</p>
                    <% else %>
                      <div
                        class="prose prose-sm prose-foreground max-w-2xl dark:prose-invert prose-pre:bg-muted prose-pre:text-foreground prose-headings:text-foreground prose-p:text-foreground prose-li:text-foreground prose-strong:text-foreground prose-em:text-foreground"
                        phx-no-format
                      >{raw(render_markdown(message.content))}</div>
                    <% end %>
                  <% end %>

                  <%= if show_streaming_indicator?(
                           message,
                           @streaming_message_id,
                           @agent_message_streams
                         ) do %>
                    <div
                      id={"message-streaming-#{message.id}"}
                      class="inline-flex max-w-fit py-1 text-muted-foreground"
                    >
                      <span
                        class="chat-streaming-dots inline-flex items-center gap-1"
                        aria-hidden="true"
                      >
                        <span class="chat-streaming-dot size-1.5 rounded-full bg-current"></span>
                        <span class="chat-streaming-dot size-1.5 rounded-full bg-current"></span>
                        <span class="chat-streaming-dot size-1.5 rounded-full bg-current"></span>
                      </span>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 px-4 pb-0 sm:px-5 lg:px-6">
            <div class="pointer-events-auto relative mx-auto w-full max-w-4xl px-6">
              <button
                id="scroll-to-bottom-btn"
                class="absolute -top-8 left-1/2 z-10 hidden -translate-x-1/2 items-center gap-1.5 rounded-full border border-border bg-background/85 px-3 py-1 text-xs font-medium text-muted-foreground shadow-md backdrop-blur transition-all hover:bg-muted hover:text-foreground"
                aria-label="Scroll to bottom"
              >
                <.icon name="hero-arrow-down" class="size-3.5" /> Scroll to bottom
              </button>
              <AppWeb.ChatComponents.chat_message_composer
                form={@message_form}
                streaming={@streaming_active?}
                layout_target_id="chat-room-layout"
              />
            </div>
          </div>
        </div>
      </div>

      <div
        data-agent-sidebar-toggle
        class={[
          "fixed inset-0 z-30 bg-black/35 backdrop-blur-sm transition-opacity lg:hidden",
          "[[data-agent-sidebar-open=false]_&]:pointer-events-none",
          "[[data-agent-sidebar-open=false]_&]:opacity-0"
        ]}
      />

      <aside
        id="chat-agent-sidebar"
        class={[
          "fixed inset-y-2 right-2 z-40 flex w-[min(22rem,calc(100vw-1rem))] flex-col overflow-hidden rounded-lg border border-border bg-background shadow-xl transition-all duration-300",
          "[[data-agent-sidebar-open=false]_&]:translate-x-[calc(100%+0.75rem)]",
          "lg:relative lg:inset-y-0 lg:right-0 lg:z-10 lg:h-full lg:w-80 lg:rounded-none lg:border-y-0 lg:border-r-0 lg:shadow-none",
          "lg:[[data-agent-sidebar-open=false]_&]:w-0 lg:[[data-agent-sidebar-open=false]_&]:translate-x-0 lg:[[data-agent-sidebar-open=false]_&]:border-l-0"
        ]}
      >
        <div class="flex min-w-0 items-start justify-between gap-3 border-b border-border px-4 py-4">
          <div class="min-w-0 space-y-1">
            <p class="text-xs font-medium uppercase text-muted-foreground">Chat room</p>
            <h1 id="chat-room-title" class="truncate text-sm font-semibold text-foreground">
              {@chat_room.title || "Untitled"}
            </h1>
          </div>

          <button
            id="chat-agent-sidebar-close"
            type="button"
            data-agent-sidebar-toggle
            aria-label="Close agents"
            class="inline-flex size-8 shrink-0 items-center justify-center rounded-lg text-muted-foreground transition hover:bg-muted hover:text-foreground"
          >
            <.icon name="hero-x-mark" class="size-4" />
          </button>
        </div>

        <div class="min-h-0 flex-1 space-y-4 overflow-y-auto px-4 py-4">
          <div class="space-y-1">
            <p class="text-sm font-semibold text-foreground">Agents</p>
            <p class="text-xs text-muted-foreground">
              Pick who replies next or add another agent to this room.
            </p>
          </div>

          <AppWeb.ChatComponents.chat_agent_selector
            id="chat-agent-selector"
            class="flex-col items-stretch gap-2"
            selected_agents={agents_in_room}
            unselected_agents={unselected}
            active_agent_id={active_agent_id(@chat_room)}
            set_active_event="set-active-agent"
            remove_event="remove-agent-from-room"
            add_event="add-agent-to-room"
            active_label="active"
          />
        </div>
      </aside>
    </div>
  <% end %>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatAgentSidebar">
    export default {
      mounted() {
        this.open = false

        this.applyState = () => {
          this.el.dataset.agentSidebarOpen = String(this.open)
          this.toggles.forEach((toggle) => {
            toggle.setAttribute("aria-expanded", String(this.open))
          })
        }

        this.toggle = () => {
          this.open = !this.open
          this.applyState()
        }

        this.bindToggles = () => {
          this.toggles = Array.from(this.el.querySelectorAll("[data-agent-sidebar-toggle]"))
          this.toggles.forEach((toggle) => toggle.addEventListener("click", this.toggle))
        }

        this.unbindToggles = () => {
          (this.toggles || []).forEach((toggle) => {
            toggle.removeEventListener("click", this.toggle)
          })
        }

        this.bindToggles()
        this.applyState()
      },

      updated() {
        this.unbindToggles()
        this.bindToggles()
        this.applyState()
      },

      destroyed() {
        this.unbindToggles()
      }
    }
  </script>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatMessages">
    export default {
      mounted() {
        this.isNearLatest = true
        this.messagesRevision = this.readMessagesRevision()
        this._programmaticScroll = false
        this.lastScrollTop = this.el.scrollTop
        this.autoscrollPaused = false
        this.touchStartY = null
        this.scrollBtn = document.getElementById("scroll-to-bottom-btn")
        this.pendingAccordionAnchor = null

        this.onScroll = () => {
          if (this._programmaticScroll) return
          this.checkScrollPosition()
        }

        this.onWheel = (event) => {
          if (event.deltaY < 0) {
            this.pauseAutoscroll()
          }
        }

        this.onTouchStart = (event) => {
          this.touchStartY = event.touches?.[0]?.clientY || null
        }

        this.onTouchMove = (event) => {
          const currentY = event.touches?.[0]?.clientY

          if (this.touchStartY !== null && currentY !== undefined && currentY - this.touchStartY > 4) {
            this.pauseAutoscroll()
          }
        }

        this.onSummaryClick = (event) => {
          const summary = event.target.closest("summary")
          if (!summary || !this.el.contains(summary)) return

          this.pendingAccordionAnchor = {
            summary,
            top: summary.getBoundingClientRect().top
          }
        }

        this.onAccordionToggle = (event) => {
          const details = event.target.closest("details")
          if (!details || !this.el.contains(details)) return

          const anchor = this.pendingAccordionAnchor
          this.pendingAccordionAnchor = null

          window.requestAnimationFrame(() => {
            this.withProgrammaticScroll(() => {
              if (this.isNearLatest) {
                this.scrollToLatest()
                return
              }

              if (!anchor || !anchor.summary?.isConnected) return

              const delta = anchor.summary.getBoundingClientRect().top - anchor.top

              if (delta !== 0) {
                this.el.scrollTop += delta
              }
            })
          })
        }

        this.onScrollButtonClick = () => {
          this.resumeAutoscroll()
          this.scrollToLatest({ behavior: "smooth" })
        }

        this.el.addEventListener("scroll", this.onScroll)
        this.el.addEventListener("wheel", this.onWheel, { passive: true })
        this.el.addEventListener("touchstart", this.onTouchStart, { passive: true })
        this.el.addEventListener("touchmove", this.onTouchMove, { passive: true })
        this.el.addEventListener("click", this.onSummaryClick)
        this.el.addEventListener("toggle", this.onAccordionToggle, true)
        if (this.scrollBtn) {
          this.scrollBtn.addEventListener("click", this.onScrollButtonClick)
        }

        this.handleEvent("scroll-to-bottom", () => {
          this.resumeAutoscroll()
          window.requestAnimationFrame(() => this.scrollToLatest())
        })

        window.requestAnimationFrame(() => {
          this.scrollToLatest()
          this.updateButtonVisibility()
        })
      },

      updated() {
        const messagesChanged = this.messagesRevision !== this.readMessagesRevision()
        this.messagesRevision = this.readMessagesRevision()

        if (messagesChanged && this.isNearLatest && !this.autoscrollPaused) {
          window.requestAnimationFrame(() => {
            this.withProgrammaticScroll(() => this.scrollToLatest())
          })
        } else {
          this.updateButtonVisibility()
        }
      },

      destroyed() {
        this.el.removeEventListener("scroll", this.onScroll)
        this.el.removeEventListener("wheel", this.onWheel, { passive: true })
        this.el.removeEventListener("touchstart", this.onTouchStart, { passive: true })
        this.el.removeEventListener("touchmove", this.onTouchMove, { passive: true })
        this.el.removeEventListener("click", this.onSummaryClick)
        this.el.removeEventListener("toggle", this.onAccordionToggle, true)
        if (this.scrollBtn) {
          this.scrollBtn.removeEventListener("click", this.onScrollButtonClick)
        }
      },

      checkScrollPosition() {
        const threshold = Math.max(this.el.clientHeight * 0.1, 72)
        const distanceFromBottom =
          this.el.scrollHeight - this.el.clientHeight - this.el.scrollTop

        if (distanceFromBottom <= threshold) {
          this.resumeAutoscroll()
        } else {
          this.pauseAutoscroll()
        }

        this.lastScrollTop = this.el.scrollTop
        this.updateButtonVisibility()
      },

      updateButtonVisibility() {
        if (this.scrollBtn) {
          this.scrollBtn.style.display = this.isNearLatest ? "none" : "flex"
        }
      },

      readMessagesRevision() {
        return this.el.dataset.messagesRevision || "0"
      },

      withProgrammaticScroll(callback) {
        this._programmaticScroll = true
        callback()
        window.requestAnimationFrame(() => {
          this._programmaticScroll = false
          this.checkScrollPosition()
        })
      },

      scrollToLatest(options = {}) {
        this.el.scrollTo({
          top: this.el.scrollHeight,
          behavior: options.behavior || "auto"
        })
        this.lastScrollTop = this.el.scrollHeight
        this.resumeAutoscroll()
        this.updateButtonVisibility()
      },

      pauseAutoscroll() {
        this.autoscrollPaused = true
        this.isNearLatest = false
      },

      resumeAutoscroll() {
        this.autoscrollPaused = false
        this.isNearLatest = true
      }
    }
  </script>
</Layouts.dashboard>
