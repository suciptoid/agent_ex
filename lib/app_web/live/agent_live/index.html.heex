<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
  sidebar_organizations={@sidebar_organizations}
>
  <div class="flex h-full min-h-0 flex-col p-4 pt-20 sm:px-5 sm:pb-5 sm:pt-20 lg:p-6">
    <div class="space-y-6">
      <div class="border-b border-border pb-6">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-2">
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Agents</h1>
            <p class="text-sm text-muted-foreground">
              Build reusable assistants that point at your providers and models.
            </p>
          </div>

          <%= if @providers == [] and @can_manage_organization? do %>
            <.link id="setup-provider-button" navigate={~p"/providers"}>
              <.button>Add Provider First</.button>
            </.link>
          <% else %>
            <.link
              :if={@can_manage_organization?}
              id="new-agent-button"
              navigate={~p"/agents/new"}
            >
              <.button>New Agent</.button>
            </.link>
          <% end %>
        </div>
      </div>

      <p
        :if={not @can_manage_organization?}
        class="rounded-2xl border border-border bg-muted/30 px-4 py-3 text-sm text-muted-foreground"
      >
        Agents can only be managed by organization owners and admins.
      </p>

      <%= if @providers == [] and @can_manage_organization? do %>
        <div class="rounded-2xl border border-dashed border-border bg-muted/30 p-6 text-sm text-muted-foreground">
          Providers power each agent. Add one first, then come back to create your assistants.
        </div>
      <% end %>

      <div id="agents" phx-update="stream" class="space-y-3" data-layout="single-column">
        <div
          :for={{dom_id, agent} <- @streams.agents}
          id={dom_id}
          data-agent-id={agent.id}
          class="rounded-2xl border border-border bg-card p-5 shadow-sm transition hover:border-primary/30"
        >
          <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="min-w-0 space-y-3">
              <div class="space-y-1">
                <div>
                  <h2 class="text-lg font-semibold text-foreground">{agent.name}</h2>
                </div>
                <div class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
                  <span id={"agent-provider-#{agent.id}"}>{provider_label(agent)}</span>
                  <span aria-hidden="true">&bull;</span>
                  <span id={"agent-model-#{agent.id}"} class="truncate">{model_name(agent)}</span>
                </div>
              </div>

              <div class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1.5 text-xs font-medium text-foreground">
                <.icon name="hero-wrench-screwdriver" class="size-3.5 text-muted-foreground" />
                <span>{tool_count_label(agent)}</span>
                <span
                  id={"agent-tools-count-#{agent.id}"}
                  class="inline-flex min-w-5 items-center justify-center rounded-full bg-background px-1.5 py-0.5 text-[11px] font-semibold text-foreground"
                >
                  {tool_count(agent)}
                </span>
              </div>
            </div>

            <div
              :if={@can_manage_organization?}
              class="flex shrink-0 items-center gap-2 self-end sm:self-auto"
            >
              <.link id={"edit-agent-#{agent.id}"} navigate={~p"/agents/#{agent.id}/edit"}>
                <.button
                  variant="outline"
                  size="icon"
                  title="Edit agent"
                  aria-label="Edit agent"
                >
                  <.icon name="hero-pencil-square" class="size-4" />
                </.button>
              </.link>
              <.button
                id={"delete-agent-#{agent.id}"}
                phx-click="delete"
                phx-value-id={agent.id}
                data-confirm="Are you sure?"
                variant="outline"
                size="icon"
                title="Delete agent"
                aria-label="Delete agent"
              >
                <.icon name="hero-trash" class="size-4" />
              </.button>
            </div>
          </div>
        </div>

        <div
          id="agents-empty-state"
          class="hidden rounded-2xl border border-dashed border-border bg-muted/30 p-10 text-center text-sm text-muted-foreground only:block"
        >
          No agents created yet.
        </div>
      </div>
    </div>
  </div>
</Layouts.dashboard>
