<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
>
  <%= if @chat_room do %>
    <div class="flex h-full min-h-0 flex-col">
      <div class="border-b border-border px-4 pb-3 pt-4 sm:px-5 lg:px-6">
        <% agents_in_room = room_agents(@chat_room) %>
        <% unselected =
          Enum.reject(@available_agents, fn available_agent ->
            Enum.any?(@chat_room.chat_room_agents, &(&1.agent_id == available_agent.id))
          end) %>
        <div class="flex min-w-0 flex-wrap items-center gap-3">
          <h1
            id="chat-room-title"
            class="min-w-0 flex-1 truncate text-base font-semibold text-foreground"
          >
            {@chat_room.title || ""}
          </h1>

          <div :if={@latest_message_id} class="w-full max-w-md flex-shrink-0">
            <AppWeb.ChatComponents.chat_agent_selector
              id="chat-agent-selector"
              class="justify-end"
              selected_agents={agents_in_room}
              unselected_agents={unselected}
              active_agent_id={active_agent_id(@chat_room)}
              set_active_event="set-active-agent"
              remove_event="remove-agent-from-room"
              add_event="add-agent-to-room"
              active_label="active"
            />
          </div>
        </div>
      </div>

      <div
        id="chat-room-layout"
        class="flex min-h-0 flex-1 flex-col pt-3 sm:pt-4 relative"
        style="--chat-composer-offset: 12rem;"
      >
        <div class="flex min-h-0 flex-1 flex-col overflow-hidden bg-card">
          <div class="flex-1 min-h-0">
            <div
              id="chat-messages"
              phx-update="stream"
              phx-hook=".ChatMessages"
              class="flex h-full min-h-full w-full flex-1 flex-col overflow-y-auto overscroll-contain pb-[var(--chat-composer-offset)]"
            >
              <div
                id="chat-messages-empty-state"
                class="mx-auto hidden h-full w-full max-w-4xl items-center justify-center px-4 py-10 text-center text-sm text-muted-foreground only:flex sm:px-5 lg:px-6"
              >
                Send the first message to start the conversation.
              </div>

              <div
                :for={{dom_id, message} <- @streams.messages}
                id={dom_id}
                class={[
                  "group mx-auto flex w-full max-w-4xl gap-2.5 px-4 py-2 transition-colors sm:px-5 lg:px-6",
                  if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                ]}
              >
                <div class={[
                  "mt-0.5 flex size-7 flex-shrink-0 items-center justify-center rounded-full text-xs font-semibold",
                  if(user_message?(message),
                    do: "bg-primary text-primary-foreground",
                    else: "bg-muted text-muted-foreground"
                  )
                ]}>
                  <.icon name={message_icon(message)} class="size-3.5" />
                </div>

                <div class={[
                  "flex min-w-0 flex-1 flex-col space-y-1",
                  if(user_message?(message), do: "items-end", else: "items-start")
                ]}>
                  <% thinking = message_thinking(message) %>
                  <% responses = tool_responses(message) %>
                  <% estimated_cost = estimated_cost_label(message) %>

                  <div class={[
                    "flex items-center gap-2 text-xs",
                    if(user_message?(message), do: "flex-row-reverse", else: "flex-row")
                  ]}>
                    <span class="font-semibold text-foreground">{speaker_name(message)}</span>
                    <span class="text-muted-foreground/50">
                      {Calendar.strftime(message.inserted_at, "%H:%M")}
                    </span>

                    <%= if responses != [] do %>
                      <span class="inline-flex items-center gap-1 rounded-full border border-amber-500/20 bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-600 dark:text-amber-400">
                        <.icon name="hero-wrench-screwdriver" class="size-3" /> tools
                      </span>
                    <% end %>

                    <%= if streaming_message?(message) do %>
                      <span class="inline-flex items-center gap-1 text-[10px] text-muted-foreground">
                        <span class="inline-block size-1.5 rounded-full bg-primary animate-pulse">
                        </span>
                        <%= if message.status == :pending do %>
                          thinking…
                        <% else %>
                          streaming…
                        <% end %>
                      </span>
                    <% end %>

                    <div
                      :if={assistant_message?(message)}
                      class="ml-auto flex items-center gap-1.5"
                    >
                      <span
                        :if={estimated_cost}
                        id={"message-cost-#{message.id}"}
                        class="pointer-events-none inline-flex items-center text-[10px] text-muted-foreground opacity-0 transition group-hover:opacity-100"
                      >
                        {estimated_cost}
                      </span>

                      <button
                        :if={
                          regeneratable_message?(message, @latest_message_id) and
                            not @streaming_active?
                        }
                        id={"regenerate-message-#{message.id}"}
                        type="button"
                        phx-click="regenerate"
                        phx-value-id={message.id}
                        title={regenerate_label(message)}
                        aria-label={regenerate_label(message)}
                        class="inline-flex size-7 items-center justify-center rounded-full text-muted-foreground opacity-0 transition hover:bg-muted hover:text-foreground group-hover:opacity-100"
                      >
                        <.icon name="hero-arrow-path" class="size-4" />
                      </button>
                    </div>
                  </div>

                  <%= if thinking not in [nil, ""] do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-thinking-#{message.id}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        open={thinking_default_expanded?(message)}
                        class="overflow-hidden rounded-lg border border-sky-500/20 bg-sky-500/5"
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class="flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium text-sky-700 hover:text-sky-800 dark:text-sky-300 dark:hover:text-sky-200 [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5"
                        >
                          <span>Thinking</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>{thinking}</span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= for {tool_response, index} <- Enum.with_index(responses) do %>
                    <.accordion
                      variant="unstyled"
                      id={"message-tool-response-#{message.id}-#{index}"}
                      class="w-full max-w-2xl"
                    >
                      <.accordion_item
                        variant="unstyled"
                        class={
                          "overflow-hidden rounded-lg border transition-colors " <>
                            if(tool_response_error?(tool_response),
                              do: "border-rose-500/20 bg-rose-500/5",
                              else: "border-amber-500/20 bg-amber-500/5"
                            )
                        }
                      >
                        <.accordion_trigger
                          variant="unstyled"
                          class={
                            "flex max-w-full items-center gap-1.5 px-3 py-2 text-[11px] font-medium [&>span]:flex [&>span]:min-w-0 [&>span]:items-center [&>span]:gap-1.5 " <>
                              if(tool_response_error?(tool_response),
                                do:
                                  "text-rose-600 hover:text-rose-700 dark:text-rose-300 dark:hover:text-rose-200",
                                else:
                                  "text-amber-600 hover:text-amber-700 dark:text-amber-400 dark:hover:text-amber-300"
                              )
                          }
                        >
                          <.icon
                            :if={tool_response_running?(tool_response)}
                            name="hero-arrow-path"
                            class="size-3 shrink-0 animate-spin"
                          />
                          <span class="shrink-0">Response</span>
                          <span class="truncate">{tool_response_label(tool_response)}</span>
                        </.accordion_trigger>
                        <.accordion_content
                          variant="unstyled"
                          class="border-t border-current/10 px-3 py-2 text-xs leading-5 text-foreground"
                        >
                          <span class="whitespace-pre-line break-words" phx-no-format>
                            {tool_response_content(tool_response)}
                          </span>
                        </.accordion_content>
                      </.accordion_item>
                    </.accordion>
                  <% end %>

                  <%= if message_has_content?(message) do %>
                    <%= if user_message?(message) do %>
                      <p
                        class="max-w-2xl whitespace-pre-line break-words rounded-2xl rounded-tr-sm bg-primary px-3 py-1.5 text-sm leading-6 text-primary-foreground"
                        phx-no-format
                      >{message.content}</p>
                    <% else %>
                      <div
                        class="prose prose-sm prose-foreground max-w-2xl dark:prose-invert prose-pre:bg-muted prose-pre:text-foreground prose-headings:text-foreground prose-p:text-foreground prose-li:text-foreground prose-strong:text-foreground prose-em:text-foreground"
                        phx-no-format
                      >{raw(render_markdown(message.content))}</div>
                    <% end %>
                  <% end %>
                </div>
              </div>
            </div>
          </div>

          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-20 px-4 pb-0 sm:px-5 lg:px-6">
            <div class="pointer-events-auto relative mx-auto w-full max-w-4xl px-6">
              <button
                id="scroll-to-bottom-btn"
                class="absolute -top-8 left-1/2 z-10 hidden -translate-x-1/2 items-center gap-1.5 rounded-full border border-border bg-background/85 px-3 py-1 text-xs font-medium text-muted-foreground shadow-md backdrop-blur transition-all hover:bg-muted hover:text-foreground"
                aria-label="Scroll to bottom"
              >
                <.icon name="hero-arrow-down" class="size-3.5" /> Scroll to bottom
              </button>
              <AppWeb.ChatComponents.chat_message_composer
                form={@message_form}
                streaming={@streaming_active?}
                layout_target_id="chat-room-layout"
              >
                <:controls>
                  <%= if @reasoning_supported? do %>
                    <.menu_button
                      id="chat-reasoning-effort-menu"
                      variant="outline"
                      content_class="w-44"
                      type="button"
                      class="h-10 gap-1.5 rounded-full border-border/70 bg-background/80 px-3.5 text-xs font-medium text-muted-foreground shadow-sm backdrop-blur transition-colors hover:bg-muted/80 hover:text-foreground"
                    >
                      <.icon name="hero-sparkles" class="size-3.5" />
                      {reasoning_button_label(@reasoning_effort)}
                      <:items>
                        <.menu_item
                          :for={{value, label} <- reasoning_effort_options()}
                          id={"chat-reasoning-effort-option-#{value}"}
                          phx-click="set-reasoning-effort"
                          phx-value-value={value}
                        >
                          <span class="flex-1">{label}</span>
                          <.icon
                            :if={@reasoning_effort == value}
                            name="hero-check"
                            class="size-4"
                          />
                        </.menu_item>
                      </:items>
                    </.menu_button>
                  <% end %>
                </:controls>
              </AppWeb.ChatComponents.chat_message_composer>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <script :type={Phoenix.LiveView.ColocatedHook} name=".ChatMessages">
    export default {
      mounted() {
        this.isNearLatest = true
        this._programmaticScroll = false
        this.scrollBtn = document.getElementById("scroll-to-bottom-btn")
        this.pendingAccordionAnchor = null

        this.onScroll = () => {
          if (this._programmaticScroll) return
          this.checkScrollPosition()
        }

        this.onSummaryClick = (event) => {
          const summary = event.target.closest("summary")
          if (!summary || !this.el.contains(summary)) return

          this.pendingAccordionAnchor = {
            summary,
            top: summary.getBoundingClientRect().top
          }
        }

        this.onAccordionToggle = (event) => {
          const details = event.target.closest("details")
          if (!details || !this.el.contains(details)) return

          const anchor = this.pendingAccordionAnchor
          this.pendingAccordionAnchor = null

          window.requestAnimationFrame(() => {
            this.withProgrammaticScroll(() => {
              if (this.isNearLatest) {
                this.scrollToLatest()
                return
              }

              if (!anchor || !anchor.summary?.isConnected) return

              const delta = anchor.summary.getBoundingClientRect().top - anchor.top

              if (delta !== 0) {
                this.el.scrollTop += delta
              }
            })
          })
        }

        this.onScrollButtonClick = () => {
          this.isNearLatest = true
          this.scrollToLatest({ behavior: "smooth" })
        }

        this.el.addEventListener("scroll", this.onScroll)
        this.el.addEventListener("click", this.onSummaryClick)
        this.el.addEventListener("toggle", this.onAccordionToggle, true)
        if (this.scrollBtn) {
          this.scrollBtn.addEventListener("click", this.onScrollButtonClick)
        }

        this.handleEvent("scroll-to-bottom", () => {
          this.isNearLatest = true
          window.requestAnimationFrame(() => this.scrollToLatest())
        })

        window.requestAnimationFrame(() => {
          this.scrollToLatest()
          this.updateButtonVisibility()
        })
      },

      updated() {
        if (this.isNearLatest) {
          window.requestAnimationFrame(() => {
            this.withProgrammaticScroll(() => this.scrollToLatest())
          })
        } else {
          this.updateButtonVisibility()
        }
      },

      destroyed() {
        this.el.removeEventListener("scroll", this.onScroll)
        this.el.removeEventListener("click", this.onSummaryClick)
        this.el.removeEventListener("toggle", this.onAccordionToggle, true)
        if (this.scrollBtn) {
          this.scrollBtn.removeEventListener("click", this.onScrollButtonClick)
        }
      },

      checkScrollPosition() {
        const threshold = Math.max(this.el.clientHeight * 0.1, 72)
        const distanceFromBottom =
          this.el.scrollHeight - this.el.clientHeight - this.el.scrollTop

        this.isNearLatest = distanceFromBottom <= threshold
        this.updateButtonVisibility()
      },

      updateButtonVisibility() {
        if (this.scrollBtn) {
          this.scrollBtn.style.display = this.isNearLatest ? "none" : "flex"
        }
      },

      withProgrammaticScroll(callback) {
        this._programmaticScroll = true
        callback()
        window.requestAnimationFrame(() => {
          this._programmaticScroll = false
          this.checkScrollPosition()
        })
      },

      scrollToLatest(options = {}) {
        this.el.scrollTo({
          top: this.el.scrollHeight,
          behavior: options.behavior || "auto"
        })
        this.isNearLatest = true
        this.updateButtonVisibility()
      }
    }
  </script>
</Layouts.dashboard>
