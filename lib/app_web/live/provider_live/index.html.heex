<Layouts.dashboard
  flash={@flash}
  current_scope={@current_scope}
  sidebar_chat_rooms={@sidebar_chat_rooms}
  sidebar_organizations={@sidebar_organizations}
>
  <div class="flex h-full min-h-0 flex-col p-4 pt-20 sm:px-5 sm:pb-5 sm:pt-20 lg:p-6">
    <div class="space-y-6">
      <div class="border-b border-border pb-6">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h1 class="text-3xl font-bold tracking-tight text-foreground">Providers</h1>
            <p class="mt-2 text-sm text-muted-foreground">
              Manage your LLM providers and API keys.
            </p>
          </div>

          <.link
            :if={@can_manage_organization?}
            id="new-provider-button"
            patch={~p"/providers/new"}
          >
            <.button>New Provider</.button>
          </.link>
        </div>
      </div>

      <p
        :if={not @can_manage_organization?}
        class="rounded-2xl border border-border bg-muted/30 px-4 py-3 text-sm text-muted-foreground"
      >
        Providers can only be managed by organization owners and admins.
      </p>

      <%= if @live_action in [:new, :edit] do %>
        <.live_component
          module={AppWeb.ProviderLive.FormComponent}
          id={@provider.id || :new}
          title={@page_title}
          action={@live_action}
          provider={@provider}
          current_scope={@current_scope}
          on_close={JS.patch(~p"/providers")}
        />
      <% end %>

      <div id="providers" phx-update="stream" class="rounded-lg border border-border bg-card">
        <div
          :for={{id, provider} <- @streams.providers}
          id={id}
          class="flex items-center justify-between gap-4 p-4 border-b border-border last:border-b-0"
        >
          <div>
            <p class="font-medium text-foreground">{provider.name || provider.provider}</p>
            <p class="text-sm text-muted-foreground">{provider.provider}</p>
          </div>
          <div :if={@can_manage_organization?} class="flex gap-2">
            <.link id={"edit-provider-#{provider.id}"} patch={~p"/providers/#{provider.id}/edit"}>
              <.button variant="outline">Edit</.button>
            </.link>
            <.button phx-click="delete" phx-value-id={provider.id} data-confirm="Are you sure?">
              Delete
            </.button>
          </div>
        </div>
        <div
          id="providers-empty-state"
          class="hidden only:block p-6 text-center text-sm text-muted-foreground"
        >
          No providers configured yet.
        </div>
      </div>
    </div>
  </div>
</Layouts.dashboard>
